# LabWeave · Nginx 示例（云上公网 + 可选内网域名）
#
# 【云上】在云 VPS 安装 Nginx，绑定公网域名与 TLS
# 【本地】不在本机装 Nginx；用 make labweave-up 或 labweave-prod-up 即可
#   1. 复制并修改路径/域名:
#      sudo cp deploy/nginx/labweave.conf.example /etc/nginx/sites-available/labweave
#      sudo sed -i "s|__LABWEAVE_ROOT__|$(pwd)|g" /etc/nginx/sites-available/labweave
#   2. 启用并重载:
#      sudo ln -sf /etc/nginx/sites-available/labweave /etc/nginx/sites-enabled/
#      sudo nginx -t && sudo systemctl reload nginx
#
# 前置: make labweave-prod-build && make labweave-prod-up

# ---------- 外网 HTTPS（公网域名）----------
server {
    listen 443 ssl http2;
    server_name labweave.example.com;

    ssl_certificate     /etc/letsencrypt/live/labweave.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/labweave.example.com/privkey.pem;

    # 限流（可选）
    # limit_req_zone 需放在 http {} 块；此处仅示例 location 级
    client_max_body_size 4m;

    root __LABWEAVE_ROOT__/frontend-web/dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:8080;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }
}

# HTTP → HTTPS 跳转（外网）
server {
    listen 80;
    server_name labweave.example.com;
    return 301 https://$host$request_uri;
}

# ---------- 内网 HTTP（ corp 域名或内网 IP）----------
server {
    listen 80;
    server_name labweave.corp.local;

    root __LABWEAVE_ROOT__/frontend-web/dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    location /api/ {
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 120s;
    }
}

# 内网 IP 直连（无 DNS 时取消注释并改 listen）
