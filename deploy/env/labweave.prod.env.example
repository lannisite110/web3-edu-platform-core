# LabWeave production environment — copy to /etc/labweave/labweave.env on cloud VPS.
# Local: cp deploy/env/labweave.prod.env.example deploy/env/labweave.prod.env
# Cloud: sudo LABWEAVE_ROOT=$(pwd) bash deploy/scripts/install-systemd.sh

# ── paths ──
LABWEAVE_ROOT=/home/ubuntu/web3home/web3-edu-platform-core
PLUGINS_DIR=..

# ── security: backends localhost-only; Nginx is public entry ──
LISTEN_HOST=127.0.0.1

GATEWAY_PORT=8080
RULE_ENGINE_PORT=8081
SCHEDULER_PORT=8082
CONTAINER_MANAGER_PORT=8083
AGENT_ASSIST_PORT=8084

RULE_ENGINE_URL=http://127.0.0.1:8081
SCHEDULER_URL=http://127.0.0.1:8082
AGENT_ASSIST_URL=http://127.0.0.1:8084
CONTAINER_MANAGER_URL=http://127.0.0.1:8083

# ── jobs: local (simulate) | cluster (K8s Pod) ──
JOB_SUBMIT_MODE=local

LABWEAVE_AGENT_MODE=local
# LABWEAVE_AGENT_API_KEY=
# LABWEAVE_AGENT_BASE_URL=
# LABWEAVE_AGENT_MODEL=gpt-4o-mini

# ── K8s (when JOB_SUBMIT_MODE=cluster) ──
# KUBECONFIG=/home/ubuntu/.kube/config
# JOB_POLL_TIMEOUT_SEC=120
# JOB_AUTO_CLEANUP=true
# JOB_SMOKE_BUSYBOX=0

# ── nginx / public ──
LABWEAVE_WEB_ROOT=${LABWEAVE_ROOT}/frontend-web/dist
LABWEAVE_PUBLIC_HOST=labweave.example.com

# Used by: sudo -E bash deploy/scripts/nginx-install.sh
# export LABWEAVE_DOMAIN=labweave.example.com
