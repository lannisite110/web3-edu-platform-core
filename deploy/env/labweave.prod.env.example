# LabWeave production environment — copy to /etc/labweave/labweave.env and edit.
# Usage: export LABWEAVE_ENV=/etc/labweave/labweave.env && make labweave-prod-up

# Absolute path to web3-edu-platform-core (required for systemd)
LABWEAVE_ROOT=/home/lxd110/web3home/web3-edu-platform-core
PLUGINS_DIR=..

# Bind backends to localhost only; Nginx is the public entry.
LISTEN_HOST=127.0.0.1

# Service ports (defaults match dev)
GATEWAY_PORT=8080
RULE_ENGINE_PORT=8081
SCHEDULER_PORT=8082
CONTAINER_MANAGER_PORT=8083
AGENT_ASSIST_PORT=8084

RULE_ENGINE_URL=http://127.0.0.1:8081
SCHEDULER_URL=http://127.0.0.1:8082
AGENT_ASSIST_URL=http://127.0.0.1:8084
CONTAINER_MANAGER_URL=http://127.0.0.1:8083

# Job dispatch: local (simulate only) | cluster (K8s Jobs for compile/sim)
JOB_SUBMIT_MODE=local

# Agent assist: local (rule-based) | llm (needs API key)
LABWEAVE_AGENT_MODE=local
# LABWEAVE_AGENT_API_KEY=
# LABWEAVE_AGENT_BASE_URL=
# LABWEAVE_AGENT_MODEL=gpt-4o-mini

# K8s cluster mode only
# KUBECONFIG=/home/lxd110/.kube/config
# JOB_POLL_TIMEOUT_SEC=120
# JOB_AUTO_CLEANUP=true
# JOB_SMOKE_BUSYBOX=0

# Nginx static root (after npm run build)
LABWEAVE_WEB_ROOT=${LABWEAVE_ROOT}/frontend-web/dist

# Public hostnames (for docs / TLS certs — not read by backends)
LABWEAVE_PUBLIC_HOST=labweave.example.com
LABWEAVE_INTERNAL_HOST=labweave.corp.local
