# LabWeave 云 / K8s cluster 模式 — 环境模板
# 用于云 VPS 连接托管 K8s，或本地 kind 集群
# cp deploy/env/labweave.cloud-k8s.env.example deploy/env/labweave.cloud-k8s.env

LABWEAVE_ROOT=/home/lxd110/web3home/web3-edu-platform-core
PLUGINS_DIR=..

LISTEN_HOST=127.0.0.1
GATEWAY_PORT=8080
RULE_ENGINE_PORT=8081
SCHEDULER_PORT=8082
CONTAINER_MANAGER_PORT=8083
AGENT_ASSIST_PORT=8084

RULE_ENGINE_URL=http://127.0.0.1:8081
SCHEDULER_URL=http://127.0.0.1:8082
AGENT_ASSIST_URL=http://127.0.0.1:8084
CONTAINER_MANAGER_URL=http://127.0.0.1:8083

# ── cluster 模式（真实 K8s Job）──
JOB_SUBMIT_MODE=cluster
KUBECONFIG=/home/lxd110/.kube/config
JOB_POLL_TIMEOUT_SEC=120
JOB_AUTO_CLEANUP=true

# 无 toolchain 镜像时用 busybox 完成调度链冒烟
JOB_SMOKE_BUSYBOX=1

# 生产有镜像后改为 0，并确保 manifest 中 tag 已 push 到集群可拉取的仓库
# JOB_SMOKE_BUSYBOX=0
# TOOLCHAIN_MANIFEST=../web3-hot-topic-labs/build-images/manifest.yaml

LABWEAVE_AGENT_MODE=local
