{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "esModuleInterop": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    "paths": {
      "@/*": ["./src/*"],
      "@sandbox/*": ["../../global-social-edu-sandbox/*"],
      "@hot-labs/*": ["../../web3-hot-topic-labs/*"],
      "@trace/*": ["../../supervision-trace-edu-suite/*"],
      "@gov/*": ["../../enterprise-gov-edu-demo/*"],
      "vue": ["./node_modules/vue/dist/vue.d.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.vue"]
}
